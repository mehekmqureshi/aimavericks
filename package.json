{
  "name": "green-passport-platform",
  "version": "1.0.0",
  "description": "AWS Native Serverless Digital Product Passport Platform",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "build:backend": "tsc -p backend/tsconfig.json",
    "build:frontend": "cd frontend && npm run build",
    "lint": "eslint . --ext .ts,.tsx",
    "provision:dynamodb": "ts-node infrastructure/provision-dynamodb.ts",
    "provision:s3": "ts-node infrastructure/provision-s3.ts",
    "provision:cognito": "ts-node infrastructure/provision-cognito.ts",
    "provision:apigateway": "ts-node infrastructure/provision-apigateway.ts",
    "provision:cloudfront": "ts-node infrastructure/provision-cloudfront.ts",
    "configure:s3-security": "ts-node infrastructure/configure-s3-security.ts",
    "test:s3-security": "ts-node infrastructure/configure-s3-security.test.ts",
    "prepare:training-data": "ts-node infrastructure/prepare-training-data.ts",
    "provision:sagemaker": "ts-node infrastructure/provision-sagemaker.ts",
    "test:sagemaker": "ts-node infrastructure/test-sagemaker-endpoint.ts",
    "seed": "ts-node infrastructure/seed-data.ts",
    "deploy:https": "npx ts-node infrastructure/deploy-https-simple.ts",
    "deploy:complete": "npm run build:frontend && npm run deploy:https",
    "verify:deployment": "npx ts-node infrastructure/verify-https-deployment.ts",
    "deploy:verify": "npm run deploy:complete && npm run verify:deployment",
    "validate:services": "npx tsx infrastructure/validate-and-repair-services.ts",
    "validate:quick": "npx tsx infrastructure/quick-validate.ts",
    "repair:services": "npx tsx infrastructure/auto-repair-services.ts",
    "deploy:full": "npx ts-node infrastructure/complete-deployment.ts"
  },
  "keywords": [
    "digital-product-passport",
    "sustainability",
    "carbon-footprint",
    "aws",
    "serverless"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@aws-sdk/client-iam": "^3.1000.0",
    "@aws-sdk/client-lambda": "^3.1000.0",
    "@types/archiver": "^7.0.0",
    "@types/aws-lambda": "^8.10.161",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "esbuild": "^0.27.3",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ngrok": "^5.0.0-beta.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "uuid": "^13.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-api-gateway": "^3.490.0",
    "@aws-sdk/client-bedrock-runtime": "^3.490.0",
    "@aws-sdk/client-cloudfront": "^3.490.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.490.0",
    "@aws-sdk/client-dynamodb": "^3.490.0",
    "@aws-sdk/client-s3": "^3.490.0",
    "@aws-sdk/client-sagemaker": "^3.490.0",
    "@aws-sdk/client-sagemaker-runtime": "^3.490.0",
    "@aws-sdk/lib-dynamodb": "^3.490.0",
    "@aws-sdk/s3-request-presigner": "^3.490.0",
    "@aws-sdk/util-dynamodb": "^3.490.0",
    "archiver": "^6.0.1",
    "fast-check": "^3.15.0",
    "qrcode": "^1.5.3"
  }
}
