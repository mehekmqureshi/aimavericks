{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DynamoDBDraftsAccess",
      "Effect": "Allow",
      "Action": [
        "dynamodb:PutItem",
        "dynamodb:GetItem"
      ],
      "Resource": "arn:aws:dynamodb:*:*:table/Drafts"
    },
    {
      "Sid": "CloudWatchLogsAccess",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": [
        "arn:aws:logs:*:*:log-group:/aws/lambda/saveDraft:*",
        "arn:aws:logs:*:*:log-group:/aws/lambda/getDraft:*"
      ]
    }
  ]
}
